{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devrules.local/schemas/developer-service-account.schema.json",
  "title": "Developer Service Account Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordType",
    "accountRef",
    "provider",
    "displayName",
    "owner",
    "identity",
    "automationProfiles",
    "status"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "recordType": { "const": "developer-service-account" },
    "accountRef": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*:[a-z0-9][a-z0-9._-]*$"
    },
    "provider": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "displayName": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "quotaPolicy": { "type": "string" }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": { "type": ["string", "null"] }
    },
    "login": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profileRef": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "automationProfiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profileId",
          "method",
          "credentialRef",
          "defaultMode",
          "writesRequireExplicitApproval",
          "status"
        ],
        "properties": {
          "profileId": { "type": "string", "minLength": 1 },
          "method": {
            "enum": ["mcp-oauth", "mcp-bearer", "cli", "rest-api", "browser", "dashboard-only"]
          },
          "toolName": { "type": "string" },
          "endpoint": { "type": "string" },
          "credentialRef": { "type": "string", "minLength": 1 },
          "defaultMode": { "enum": ["read-only", "read-write"] },
          "writesRequireExplicitApproval": { "const": true },
          "expectedIdentity": {
            "type": "object",
            "additionalProperties": { "type": ["string", "null"] }
          },
          "status": { "enum": ["planned", "configured", "verified", "blocked", "retired"] },
          "lastVerified": { "type": ["string", "null"] }
        }
      }
    },
    "status": { "enum": ["draft", "active", "read-only", "blocked", "retired"] },
    "lastVerified": { "type": ["string", "null"] }
  }
}
