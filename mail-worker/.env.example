# Never commit real credentials. Copy this file to .env.local only for deployment.
CLOUDFLARE_API_TOKEN=
# 16-30 characters. Use a unique randomly generated password and do not quote it.
CLOUDMAIL_ADMIN_PASSWORD=

# Fixed Cloudflare-verified digest recipient. Install it with
# `wrangler secret put AI_DIGEST_DESTINATION_SECRET`; never accept it from a request.
AI_DIGEST_DESTINATION_SECRET=

# AI monitoring uses a Cloudflare binding, not an API key. It remains disabled by
# default in wrangler.toml; no additional secret is required.
